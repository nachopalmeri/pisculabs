---
<footer>
  <div class="wrap">
    <div class="f-row">
      <span class="f-logo">pisculichi<em>.</em>labs</span>
      <ul class="f-links">
        <li><a href="/">Inicio</a></li>
        <li><a href="/#servicios">Servicios</a></li>
        <li><a href="/#faq">FAQ</a></li>
        <li><a href="/#contacto">Contacto</a></li>
      </ul>
      <span class="f-copy">&copy; 2025 Pisculichi Labs &middot; Zona sur, Buenos Aires</span>
    </div>
  </div>
</footer>

<style>
  /* FOOTER */
  footer {
    border-top: 2px solid var(--border);
    padding: 48px 0;
    position: relative;
    z-index: 1;
    background: var(--bg);
  }
  .f-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px;
  }
  .f-logo {
    font-family: var(--f-hero);
    font-size: 20px;
    color: var(--text);
  }
  .f-logo em {
    font-style: normal;
    color: var(--violet);
  }
  .f-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }
  .f-links a {
    font-family: var(--f-ui);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--text-2);
    transition: color .2s;
  }
  .f-links a:hover {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .f-copy {
    font-family: var(--f-ui);
    font-size: 10px;
    color: var(--text-3);
  }

  @media (max-width: 600px) {
    .f-row {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
