---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import proyectosData from '../data/proyectos.json';

// En la de proyectos mostramos TODOS (No filtramos por hideInHome)
---

<Layout title="Proyectos — Pisculichi Labs">
  <Navbar />
  
  <div class="page-header">
    <div class="wrap">
      <a href="/" class="back sr">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Volver al inicio
      </a>
      <h1 class="sr d1">Proyectos<br/><span>reales.</span></h1>
      <p class="sr d2">Software que construimos y está en uso hoy. Con el problema que resolvió, el resultado que obtuvo y lo que costaría armar algo similar para vos.</p>
    </div>
  </div>

  {proyectosData.map((proj) => (
    <div class="proj-entry" id={proj.id}>
      <div class="wrap">
        <div class="proj-layout">
          <div class="sr">
            <div class="proj-label">{proj.categories.join(' · ')}</div>
            <h2 class="proj-title">{proj.titlePrefix}<span style="color:var(--violet)">{proj.titleHighlight}</span></h2>
            <p class="proj-tagline">{proj.tagline}</p>
            <div class="proj-problem-title">El problema</div>
            <p class="proj-problem-text">{proj.problem}</p>
            <div class="proj-result">{proj.result}</div>
            <div class="proj-actions">
              <a href={proj.link} target="_blank" rel="noopener" class="btn btn-v">Ver demo en vivo &#x2197;</a>
              <a href="/#contacto" class="btn btn-o">Quiero un sistema así</a>
            </div>
          </div>
          <div class="sr d1">
            <div class="proj-meta">
              <div class="meta-row"><span class="meta-icon">&#x1F4B0;</span>
                <div>
                  <div class="meta-label">Precio referencial</div>
                  {Object.entries(proj.prices).map(([key, value], index) => (
                      <div class={index === 0 ? "meta-val green" : "meta-val"} style={index !== 0 ? "margin-top:4px" : ""}>
                         {key === 'group' && 'Para un grupo/club: '}
                         {key === 'db' && 'Con base de datos: '}
                         {key === 'other' && 'Para otra persona: '}
                         {key === 'multi' && 'Multi-usuario/local: '}
                         {key === 'base' && 'Desde: '}
                         {key === 'custom' && 'A medida/Custom: '}
                         {value}
                      </div>
                  ))}
                </div>
              </div>
              <div class="meta-row"><span class="meta-icon">&#x23F1;&#xFE0F;</span>
                <div>
                  <div class="meta-label">Tiempo de desarrollo</div>
                  <div class="meta-val">{proj.devTime}</div>
                </div>
              </div>
              <div class="meta-row"><span class="meta-icon">&#x1F6E0;&#xFE0F;</span>
                <div>
                  <div class="meta-label">Tecnologías</div>
                  <div class="meta-val">
                    {proj.stack.map(tech => <span class="tag">{tech}</span>)}
                  </div>
                </div>
              </div>
              <div class="meta-row"><span class="meta-icon">&#x1F4F1;</span>
                <div>
                    <div class="meta-label">Detalles</div>
                    <div class="meta-val">Depende de la escalabilidad, consultanos.</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  ))}

  <div class="cta-strip">
    <div class="wrap">
      <div class="sr">
        <h2>¿Tu proyecto no<br/><span>está acá</span>?</h2>
        <p>No importa. Estos son ejemplos de lo que ya construimos. <strong>Si podés describirlo, lo podemos construir.</strong></p>
        <div class="strip-btns">
          <a href="https://wa.me/5491100000000?text=Hola%2C+vi+los+proyectos+de+Pisculichi+Labs+y+quiero+consultar" target="_blank" rel="noopener" class="btn btn-wsp">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
            Escribinos por WhatsApp
          </a>
          <a href="/#contacto" class="btn btn-o">Mandar consulta &#x2192;</a>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<style>
/* PAGE HEADER */
.page-header {
  padding: 160px 0 100px;
  position: relative;
  z-index: 1;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}
.page-header .back {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--f-ui);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: 40px;
  transition: color .2s;
}
.page-header .back:hover { color: var(--text); }
.page-header h1 {
  font-family: var(--f-hero);
  font-size: clamp(48px, 9vw, 120px);
  letter-spacing: -0.01em;
  line-height: .93;
  margin-bottom: 24px;
}
.page-header h1 span { color: var(--violet); }
.page-header p {
  font-size: 18px;
  color: var(--text-2);
  max-width: 640px;
  line-height: 1.6;
}

/* PROJECT ENTRIES */
.proj-entry {
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  padding: 100px 0;
  position: relative;
  z-index: 1;
}
.proj-entry:nth-child(even) {
  background: rgba(255, 255, 255, 0.01);
}
.proj-entry:last-child { border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
.proj-layout {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 80px;
  align-items: start;
}
.proj-label {
  font-family: var(--f-ui);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .25em;
  text-transform: uppercase;
  color: var(--violet);
  margin-bottom: 16px;
}
.proj-title {
  font-family: var(--f-hero);
  font-size: clamp(40px, 6vw, 84px);
  letter-spacing: -0.01em;
  line-height: .95;
  margin-bottom: 24px;
}
.proj-tagline {
  font-size: 18px;
  color: var(--text-2);
  line-height: 1.7;
  margin-bottom: 40px;
}
.proj-problem-title {
  font-family: var(--f-ui);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: 12px;
}
.proj-problem-text {
  font-size: 16px;
  color: var(--text-2);
  line-height: 1.7;
  margin-bottom: 40px;
}
.proj-result {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 24px 28px;
  background: rgba(16, 185, 129, 0.05);
  border: 1px solid rgba(16, 185, 129, 0.2);
  border-radius: 8px;
  font-size: 15px;
  font-weight: 500;
  color: var(--text);
  line-height: 1.6;
  margin-bottom: 48px;
}
.proj-result::before {
  content: '→';
  font-family: var(--f-hero);
  font-size: 24px;
  color: var(--green);
  flex-shrink: 0;
  line-height: 1;
  margin-top: -2px;
}
.proj-actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

/* Meta panel */
.proj-meta {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 8px;
  backdrop-filter: blur(10px);
  padding: 0;
}
.meta-row {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  padding: 24px 32px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}
.meta-row:last-child { border-bottom: none; }
.meta-icon {
  font-size: 24px;
  flex-shrink: 0;
  margin-top: -2px;
}
.meta-label {
  font-family: var(--f-ui);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: 8px;
}
.meta-val {
  font-size: 15px;
  color: var(--text);
  line-height: 1.6;
}
.meta-val.green { color: var(--green); font-weight: 600; font-size: 16px; }
.meta-val .tag {
  display: inline-block;
  font-family: var(--f-ui);
  font-size: 11px;
  font-weight: 600;
  padding: 4px 10px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.03);
  border-radius: 4px;
  color: var(--text-2);
  margin: 4px 4px 0 0;
}

/* CTA STRIP */
.cta-strip {
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  background: var(--bg-1);
  padding: 120px 0;
  position: relative;
  z-index: 1;
  text-align: center;
}
.cta-strip h2 {
  font-family: var(--f-hero);
  font-size: clamp(42px, 7vw, 92px);
  letter-spacing: -0.01em;
  line-height: .95;
  margin-bottom: 24px;
}
.cta-strip h2 span { color: var(--violet); }
.cta-strip p {
  font-size: 18px;
  color: var(--text-2);
  margin-bottom: 40px;
  max-width: 560px;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.6;
}
.cta-strip p strong { color: var(--text); font-weight: 700; }
.strip-btns {
  display: flex;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
}

@media (max-width: 960px) {
  .proj-layout { grid-template-columns: 1fr; gap: 60px; }
}
</style>
